{
  "name": "blksm-academy",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run start:dev --workspace=apps/api",
    "dev:web": "npm run dev --workspace=apps/web",
    "build:shared": "npm run build --workspace=packages/shared",
    "build:api": "npm run build --workspace=apps/api",
    "build:web": "npm run build --workspace=apps/web",
    "db:migrate": "npm run db:migrate --workspace=apps/api",
    "db:seed": "npm run db:seed --workspace=apps/api",
    "db:wipe-demo": "npm run db:wipe-demo --workspace=apps/api",
    "dev:postgres": "node scripts/dev-postgres.mjs"
  },
  "devDependencies": {
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "embedded-postgres": "^18.4.0-beta.17"
  }
}
