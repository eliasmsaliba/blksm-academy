# --- Postgres ---
POSTGRES_USER=blksm
POSTGRES_PASSWORD=blksm_dev_password
POSTGRES_DB=blksm_academy
POSTGRES_PORT=5432
DATABASE_URL=postgresql://blksm:blksm_dev_password@localhost:5432/blksm_academy?schema=public

# --- API ---
NODE_ENV=development
API_PORT=4000
ACCESS_TOKEN_SECRET=change-me-access-secret-min-32-chars
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
COOKIE_DOMAIN=localhost
CORS_ORIGIN=http://localhost:3000

# --- Storage ---
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./storage/uploads

# --- Web ---
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# --- Seed ---
SEED_SUPERADMIN_EMAIL=superadmin@blksmevents.com
SEED_SUPERADMIN_PASSWORD=ChangeMe123!
